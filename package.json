{
  "name": "cattle-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Multi-account autonomous Cattle Farm claim bot",
  "scripts": {
    "start": "node cattle_bot.js",
    "once": "node cattle_bot.js --once",
